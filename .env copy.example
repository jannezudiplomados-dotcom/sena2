# ============================================
# Copia este archivo como .env y completa los valores.
# NUNCA subas el archivo .env real al repositorio.
# ============================================

# --- Flask ---
# Genera uno con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_por_un_valor_largo_y_aleatorio
FLASK_DEBUG=0
HOST=127.0.0.1
PORT=5000
# Pon 1 solo cuando sirvas por HTTPS
SESSION_COOKIE_SECURE=0

# --- Base de datos MySQL ---
DB_HOST=localhost
DB_USER=sena_app
DB_PASSWORD=tu_password_seguro
DB_NAME=gestion_fichas
DB_POOL_SIZE=5

# --- Seguridad de login ---
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# --- Paginacion ---
PER_PAGE=10
